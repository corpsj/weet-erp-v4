# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# sisyphus
.sisyphus/

# typescript
*.tsbuildinfo
next-env.d.ts

# python backend
backend/.venv/
backend/.env
backend/__pycache__/
backend/.pytest_cache/
backend/*.db
*.pyc
backend/.sessions/
